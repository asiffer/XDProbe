[Unit]
Description=XDProbe as a service
Documentation=https://github.com/asiffer/XDProbe
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=xdprobe
Group=xdprobe
ExecStart=/usr/local/bin/xdprobe
ExecStartPre=-rm -f /run/xdprobe/xdprobe.sock
Restart=on-failure
RestartSec=5
TimeoutStartSec=10
TimeoutStopSec=10
EnvironmentFile=-/etc/sysconfig/xdprobe

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=xdprobe

# Hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/run/xdprobe/xdprobe.sock
CapabilityBoundingSet=CAP_NET_ADMIN
AmbientCapabilities=CAP_NET_ADMIN
LockPersonality=yes
ProtectKernelTunables=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
PrivateDevices=yes
ProtectHostname=yes
ProtectKernelModules=yes
ProtectProc=invisible
RestrictAddressFamilies=AF_UNIX
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
UMask=0077

[Install]
WantedBy=multi-user.target